## Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000

## Geocoding (required by Nominatim policy)
NOMINATIM_USER_AGENT="ZiweiAI/1.0 (contact: you@example.com)"

## Database (Neon serverless Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

## Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...  # legacy one-time
STRIPE_SUBSCRIPTION_PRICE_ID=price_...  # NEW: $4.99/month subscription
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_COUPON_50_OFF_ID=coupon_...  # Optional
ORDER_NOTIFICATION_EMAIL=orders@yourdomain.com,founder@yourdomain.com
READING_TURNAROUND_HOURS=48

## Auth
SESSION_SECRET=at-least-32-characters-long-random-string-change-me

## AI (horoscope generation)
DEEPSEEK_API_KEY=sk-...
OPENAI_API_KEY=sk-...  # fallback

## Push Notifications
ONESIGNAL_APP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONESIGNAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

## Cron
CRON_SECRET=random-secret-for-cron-auth

## Ops automation
# OPS_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...

## Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM="DestinyBlueprint <support@yourdomain.com>"

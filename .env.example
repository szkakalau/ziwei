## Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000

## Geocoding (required by Nominatim policy)
NOMINATIM_USER_AGENT="ZiweiAI/1.0 (contact: you@example.com)"

## Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

## Email (SMTP)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Ziwei AI <support@yourdomain.com>"

# Public site URL (no trailing slash). Used for metadataBase, sitemap, and OG URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Primary CTA: checkout or in-app URL for “Get my reading” (Navbar + Pricing). Omit to use site home (/).
# NEXT_PUBLIC_READING_URL=https://your-product.com/start

# Nominatim (OpenStreetMap) geocoding—use a real app name and contact email per their usage policy.
# NOMINATIM_USER_AGENT=YourSite/1.0 (you@yourdomain.com)


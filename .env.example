## Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000

## Geocoding (required by Nominatim policy)
NOMINATIM_USER_AGENT="ZiweiAI/1.0 (contact: you@example.com)"

## Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

## Birth chart API (POST /api/birth-chart)
# Optional JSON field: "includeZhChart": true  → response includes "chartZh" (zh-CN plain JSON for PDF grid).

## Paid PDF (OpenAI Chat Completions — twelve-palace English commentary)
OPENAI_API_KEY=sk-...
# Optional: default gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# Optional: Azure / proxy OpenAI-compatible API
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: self-host a smaller Noto Sans SC OTF instead of jsDelivr on first PDF request
# NOTO_SANS_SC_OTF_URL=https://your-cdn/NotoSansSC-Regular.otf

## Email (SMTP)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Ziwei AI <support@yourdomain.com>"

# Public site URL (no trailing slash). Used for metadataBase, sitemap, and OG URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Primary CTA: checkout or in-app URL for “Get my reading” (Navbar + Pricing). Omit to use site home (/).
# NEXT_PUBLIC_READING_URL=https://your-product.com/start

# Nominatim (OpenStreetMap) geocoding—use a real app name and contact email per their usage policy.
# NOMINATIM_USER_AGENT=YourSite/1.0 (you@yourdomain.com)

# --- Future integrations (not used by the marketing scaffold runtime) ---
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# MAILERLITE_API_KEY=
